"""Minimal GPS metadata extractor used by classifier.py."""

from PIL import Image
from PIL.ExifTags import TAGS, GPSTAGS


def _to_decimal(dms, ref):
    degrees, minutes, seconds = dms
    decimal = float(degrees) + float(minutes) / 60 + float(seconds) / 3600
    if ref in ("S", "W"):
        decimal = -decimal
    return decimal


def extract_gps(image_path: str) -> dict:
    """Return {'latitude': float, 'longitude': float} if EXIF GPS data exists, else {}."""
    try:
        img = Image.open(image_path)
        exif_data = img._getexif()
        if not exif_data:
            return {}

        gps_info = {}
        for tag_id, value in exif_data.items():
            tag = TAGS.get(tag_id, tag_id)
            if tag == "GPSInfo":
                for gps_tag_id, gps_value in value.items():
                    gps_tag = GPSTAGS.get(gps_tag_id, gps_tag_id)
                    gps_info[gps_tag] = gps_value

        if not gps_info:
            return {}

        lat = _to_decimal(gps_info["GPSLatitude"], gps_info["GPSLatitudeRef"])
        lon = _to_decimal(gps_info["GPSLongitude"], gps_info["GPSLongitudeRef"])
        return {"latitude": lat, "longitude": lon}
    except Exception:
        return {}
